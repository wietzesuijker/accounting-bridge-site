---
import Base from '../../layouts/Base.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
)
---

<Base title="Blog - Accounting Bridge" description="Practical guides for multi-entity financial consolidation, month-end close, and trial balance automation.">
  <Header />
  <main class="pt-24 pb-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h1 class="text-3xl font-bold text-dark mb-2">Blog</h1>
      <p class="text-muted mb-10">Practical guides for finance teams consolidating across entities.</p>

      <div class="space-y-8">
        {posts.map((post) => (
          <article class="group">
            <a href={`/blog/${post.id}`} class="block no-underline">
              <p class="text-sm text-muted mb-1">
                {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
              </p>
              <h2 class="text-xl font-bold text-dark group-hover:text-primary transition-colors mb-1">
                {post.data.title}
              </h2>
              <p class="text-muted text-sm">{post.data.description}</p>
            </a>
          </article>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Base>
