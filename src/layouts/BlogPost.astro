---
import Base from './Base.astro'
import Header from '../components/Header.astro'
import EmailCapture from '../components/EmailCapture.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title: string
  description: string
  date: Date
}

const { title, description, date } = Astro.props
const APP_URL = "https://app.accounting-bridge.com"
const dateStr = date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })
---

<Base title={`${title} - Accounting Bridge`} description={description}>
  <Header />
  <main class="pt-24 pb-16">
    <article class="max-w-3xl mx-auto px-4 sm:px-6">
      <header class="mb-10">
        <p class="text-sm text-muted mb-2">{dateStr}</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-dark leading-tight">{title}</h1>
        <p class="text-lg text-muted mt-3">{description}</p>
      </header>

      <div class="prose prose-gray max-w-none
        [&>h2]:text-xl [&>h2]:font-bold [&>h2]:text-dark [&>h2]:mt-10 [&>h2]:mb-3
        [&>h3]:text-lg [&>h3]:font-semibold [&>h3]:text-dark [&>h3]:mt-8 [&>h3]:mb-2
        [&>p]:text-muted [&>p]:leading-relaxed [&>p]:mb-4
        [&>ul]:text-muted [&>ul]:space-y-1 [&>ul]:mb-4 [&>ul]:list-disc [&>ul]:pl-6
        [&>ol]:text-muted [&>ol]:space-y-1 [&>ol]:mb-4 [&>ol]:list-decimal [&>ol]:pl-6
        [&>blockquote]:border-l-4 [&>blockquote]:border-primary [&>blockquote]:pl-4 [&>blockquote]:italic [&>blockquote]:text-muted
        [&_strong]:text-dark [&_a]:text-primary [&_a]:hover:underline">
        <slot />
      </div>

      <!-- CTA -->
      <div class="mt-12 p-6 bg-surface rounded-xl border border-border text-center">
        <p class="text-lg font-semibold text-dark mb-2">Try it with your own files</p>
        <p class="text-muted text-sm mb-4">Upload trial balances from any ERP. Consolidated Excel in 30 seconds.</p>
        <a href={`${APP_URL}/demo`}
           class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-primary hover:bg-primary-hover rounded-lg transition-colors no-underline">
          Try the demo - no login needed
        </a>
      </div>
    </article>

    <div class="mt-12">
      <EmailCapture />
    </div>
  </main>
  <Footer />

  <!-- JSON-LD structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "datePublished": date.toISOString(),
    "author": { "@type": "Organization", "name": "Accounting Bridge" },
    "publisher": { "@type": "Organization", "name": "Accounting Bridge", "url": "https://accounting-bridge.com" }
  })} />
</Base>
