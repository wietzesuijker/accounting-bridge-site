---
const APP_URL = "https://app.accounting-bridge.com"
---

<section id="pricing" class="py-20 sm:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-4 fade-in-up">
      <h2 class="text-3xl sm:text-4xl font-bold text-dark mb-4">Pricing</h2>
      <p class="text-lg text-muted max-w-xl mx-auto">
        30-day free trial on all plans. No implementation cost. No IT. Cancel anytime.
      </p>

      <!-- Monthly / Annual toggle -->
      <div class="mt-6 inline-flex items-center gap-1 bg-surface rounded-full p-1">
        <button id="btn-monthly" class="px-4 py-1.5 text-sm font-semibold rounded-full bg-white text-dark shadow-sm transition-all">
          Monthly
        </button>
        <button id="btn-annual" class="px-4 py-1.5 text-sm font-semibold rounded-full text-muted transition-all">
          Annual <span class="text-xs font-bold text-primary ml-1">Save 20%</span>
        </button>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-8 lg:gap-6 mt-16">
      <!-- Solo -->
      <div class="fade-in-up rounded-2xl p-8 bg-white border border-border shadow-sm flex flex-col">
        <h3 class="text-lg font-bold text-dark">Solo</h3>
        <div class="mt-4 mb-2">
          <span class="price-amount text-4xl font-extrabold text-dark" data-monthly="$49" data-annual="$39">$49</span>
          <span class="text-muted">/mo</span>
          <span class="billing-note text-xs text-muted block mt-1 min-h-[1rem]" data-monthly=" " data-annual="billed annually ($468/yr)"> </span>
        </div>
        <p class="text-sm text-muted mb-8">One person, one consolidation. Excel in, Excel out.</p>
        <ul class="space-y-3 text-sm text-muted mb-8 flex-grow">
          <li class="flex gap-2"><span class="text-primary">&#x2713;</span> Up to 3 entities</li>
          <li class="flex gap-2"><span class="text-primary">&#x2713;</span> 1 user</li>
          <li class="flex gap-2"><span class="text-primary">&#x2713;</span> All 4 processing modes</li>
          <li class="flex gap-2"><span class="text-primary">&#x2713;</span> AI narrative summaries</li>
          <li class="flex gap-2"><span class="text-primary">&#x2713;</span> Email support</li>
        </ul>
        <a href={APP_URL}
           class="block text-center px-6 py-3 text-sm font-semibold text-primary border-2 border-primary/20 hover:border-primary/40 rounded-xl transition-colors no-underline">
          Start free trial
        </a>
      </div>

      <!-- Team (featured) -->
      <div class="fade-in-up rounded-2xl p-8 bg-white border-2 border-primary shadow-lg shadow-primary/10 flex flex-col relative">
        <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 px-4 py-1 bg-primary text-white text-xs font-bold rounded-full">
          Most popular
        </div>
        <h3 class="text-lg font-bold text-dark">Team</h3>
        <div class="mt-4 mb-2">
          <span class="price-amount text-4xl font-extrabold text-dark" data-monthly="$99" data-annual="$79">$99</span>
          <span class="text-muted">/mo</span>
          <span class="billing-note text-xs text-muted block mt-1 min-h-[1rem]" data-monthly=" " data-annual="billed annually ($948/yr)"> </span>
        </div>
        <p class="text-sm text-muted mb-8">Stop chasing files across entities. One consolidated TB, audit-ready, every month.</p>
        <ul class="space-y-3 text-sm text-muted mb-8 flex-grow">
          <li class="flex gap-2"><span class="text-primary">&#x2713;</span> Unlimited entities</li>
          <li class="flex gap-2"><span class="text-primary">&#x2713;</span> Up to 5 users</li>
          <li class="flex gap-2"><span class="text-primary">&#x2713;</span> All 4 processing modes</li>
          <li class="flex gap-2"><span class="text-primary">&#x2713;</span> AI narrative summaries</li>
          <li class="flex gap-2"><span class="text-primary">&#x2713;</span> Priority support</li>
        </ul>
        <a href={APP_URL}
           class="block text-center px-6 py-3 text-sm font-semibold text-white bg-primary hover:bg-primary-hover rounded-xl transition-colors no-underline">
          Start free trial
        </a>
      </div>

      <!-- Scale -->
      <div class="fade-in-up rounded-2xl p-8 bg-white border border-border shadow-sm flex flex-col">
        <h3 class="text-lg font-bold text-dark">Scale</h3>
        <div class="mt-4 mb-2">
          <span class="price-amount text-4xl font-extrabold text-dark" data-monthly="$249" data-annual="$199">$249</span>
          <span class="text-muted">/mo</span>
          <span class="billing-note text-xs text-muted block mt-1 min-h-[1rem]" data-monthly=" " data-annual="billed annually ($2,388/yr)"> </span>
        </div>
        <p class="text-sm text-muted mb-8">Roll out across your portfolio. Unlimited entities and users.</p>
        <ul class="space-y-3 text-sm text-muted mb-8 flex-grow">
          <li class="flex gap-2"><span class="text-primary">&#x2713;</span> Unlimited entities & users</li>
          <li class="flex gap-2"><span class="text-primary">&#x2713;</span> Dedicated onboarding</li>
          <li class="flex gap-2"><span class="text-primary">&#x2713;</span> Custom KPI definitions</li>
          <li class="flex gap-2"><span class="text-primary">&#x2713;</span> Priority support</li>
          <li class="flex gap-2"><span class="text-primary">&#x2713;</span> Vendor security questionnaire</li>
        </ul>
        <a href="mailto:wietze.suijker@gmail.com?subject=Accounting%20Bridge%20Scale"
           class="block text-center px-6 py-3 text-sm font-semibold text-primary border-2 border-primary/20 hover:border-primary/40 rounded-xl transition-colors no-underline">
          Contact us
        </a>
      </div>
    </div>

    <!-- Bottom CTA for finance leaders -->
    <div class="fade-in-up mt-16 max-w-2xl mx-auto text-center">
      <p class="text-muted leading-relaxed">
        Your team spends 10-40 hours a month on manual consolidation. At a $75 loaded rate, that's
        $9,000-36,000/year in recoverable labor - vs $588-2,988/year for Accounting Bridge.
        No IT project. No implementation fee. Cancel if it doesn't deliver in 30 days.
      </p>
    </div>
  </div>
</section>

<script>
  const btnMonthly = document.getElementById("btn-monthly")!;
  const btnAnnual = document.getElementById("btn-annual")!;
  const prices = document.querySelectorAll<HTMLElement>(".price-amount");
  const notes = document.querySelectorAll<HTMLElement>(".billing-note");

  function setBilling(period: "monthly" | "annual") {
    prices.forEach((el) => { el.textContent = el.dataset[period]!; });
    notes.forEach((el) => { el.textContent = el.dataset[period]!; });

    if (period === "annual") {
      btnAnnual.classList.add("bg-white", "text-dark", "shadow-sm");
      btnAnnual.classList.remove("text-muted");
      btnMonthly.classList.remove("bg-white", "text-dark", "shadow-sm");
      btnMonthly.classList.add("text-muted");
    } else {
      btnMonthly.classList.add("bg-white", "text-dark", "shadow-sm");
      btnMonthly.classList.remove("text-muted");
      btnAnnual.classList.remove("bg-white", "text-dark", "shadow-sm");
      btnAnnual.classList.add("text-muted");
    }
  }

  btnMonthly.addEventListener("click", () => setBilling("monthly"));
  btnAnnual.addEventListener("click", () => setBilling("annual"));
</script>
