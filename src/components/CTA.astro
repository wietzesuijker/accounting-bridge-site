---
const APP_URL = "https://app.accounting-bridge.com"
---

<section class="py-20 sm:py-28 bg-gradient-to-br from-primary to-primary-hover text-white">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center fade-in-up">
    <h2 class="text-3xl sm:text-4xl font-bold mb-6">
      Your month-end, in 10 minutes
    </h2>
    <p class="text-lg text-white/80 mb-10 max-w-xl mx-auto">
      No implementation cost. No IT project. Cancel if it doesn't deliver in 30 days.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={`${APP_URL}/demo`}
         class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-primary bg-white hover:bg-white/90 rounded-xl transition-colors no-underline">
        Try the demo
      </a>
      <a href={APP_URL}
         class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-white border-2 border-white/30 hover:border-white/50 rounded-xl transition-colors no-underline">
        Start free trial
      </a>
    </div>
  </div>
</section>
